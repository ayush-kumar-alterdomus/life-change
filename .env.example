# ===========================================
# Ascend Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# for local development.

# PostgreSQL Configuration
POSTGRES_DB=ascend_dev
POSTGRES_USER=ascend
POSTGRES_PASSWORD=ascend_dev_pass
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Firebase Configuration
FIREBASE_PROJECT_ID=ascend-dev
FIREBASE_CREDENTIALS_FILE=firebase-service-account.json

# Database URL (used by staging/prod profiles)
DATABASE_URL=jdbc:postgresql://localhost:5432/ascend_dev
DATABASE_USERNAME=ascend
DATABASE_PASSWORD=ascend_dev_pass
